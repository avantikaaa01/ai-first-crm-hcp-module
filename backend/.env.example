# Groq API key - create a new one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model config
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Database - defaults to local SQLite for easy setup.
# For Postgres, use: postgresql+psycopg2://user:password@localhost:5432/hcp_crm
DATABASE_URL=sqlite:///./hcp_crm.db
